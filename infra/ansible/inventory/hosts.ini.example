[azure]
# Replace <PUBLIC_IP> with the Azure VM public IP from Terraform output.
# Example:
# 52.123.45.67 ansible_user=azureuser ansible_ssh_private_key_file=~/.ssh/id_ed25519 ansible_python_interpreter=/usr/bin/python3

<public_ip> ansible_user=azureuser ansible_ssh_private_key_file=~/.ssh/id_ed25519 ansible_python_interpreter=/usr/bin/python3
