    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (type, provider) (ai_generation_seconds_sum{type=~\"${task:regex}\",provider=~\"${provider:regex}\"}) / sum by (type, provider) (ai_generation_seconds_count{type=~\"${task:regex}\",provider=~\"${provider:regex}\"})",
          "legendFormat": "avg {{type}} ({{provider}})",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (type, provider, le) (rate(ai_generation_seconds_bucket{type=~\"${task:regex}\",provider=~\"${provider:regex}\"}[30m])))",
          "legendFormat": "p95 {{type}} ({{provider}})",
          "refId": "B"
        }
      ],
      "title": "AI task duration (avg + p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Each row is a duration bucket (seconds). Color shows how many tasks finished within that upper bound. Steps appear when new generations complete.",
      "fieldConfig": {
        "defaults": {
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 11,
      "options": {
        "calculate": false,
        "cellGap": 2,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Oranges",
          "steps": 64
        },
        "exemplars": { "color": "rgba(255,0,255,0.7)" },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "rowsFrame": { "layout": "auto" },
        "tooltip": { "mode": "single", "showColorScale": true, "yHistogram": false },
        "yAxis": {
          "axisLabel": "Duration ≤ (s)",
          "axisPlacement": "left",
          "decimals": 0,
          "reverse": false,
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "sum by (le) (ai_generation_seconds_bucket{type=~\"${task:regex}\",provider=~\"${provider:regex}\",le!=\"+Inf\"})",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "title": "Duration distribution (heatmap)",
      "type": "heatmap"
    },
