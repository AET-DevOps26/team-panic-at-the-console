{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "incident.comment.added",
  "description": "Carries commentId so subscribers can fetch the specific comment without scanning all comments on the incident.",
  "type": "object",
  "required": ["incidentId", "commentId", "timestamp"],
  "additionalProperties": false,
  "properties": {
    "incidentId": { "type": "string", "format": "uuid" },
    "commentId": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
