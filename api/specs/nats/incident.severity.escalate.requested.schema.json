{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://github.com/aet-devops26/team-panic-at-the-console/api/specs/nats/incident.severity.escalate.requested.schema.json",
  "type": "object",
  "required": ["incidentId", "requestedSeverity", "timestamp"],
  "additionalProperties": false,
  "properties": {
    "incidentId": { "type": "string", "format": "uuid" },
    "requestedSeverity": { "type": "string", "enum": ["SEV1", "SEV2", "SEV3", "SEV4"] },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
