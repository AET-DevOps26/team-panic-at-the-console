{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://github.com/aet-devops26/team-panic-at-the-console/api/specs/nats/incident.genai.postmortem.generated.schema.json",
  "description": "Published by genai-service after generating a postmortem. incident-service subscribes and persists the result.",
  "type": "object",
  "required": ["incidentId", "timestamp", "rootCause", "timeline", "actionItems"],
  "additionalProperties": false,
  "properties": {
    "incidentId": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "rootCause": { "type": "string", "minLength": 1 },
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "actionItems": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
