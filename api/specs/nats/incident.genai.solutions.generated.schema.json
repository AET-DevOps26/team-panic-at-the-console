{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://github.com/aet-devops26/team-panic-at-the-console/api/specs/nats/incident.genai.solutions.generated.schema.json",
  "description": "Published by genai-service after generating solution suggestions. incident-service subscribes and persists the result.",
  "type": "object",
  "required": ["incidentId", "timestamp", "solutions"],
  "additionalProperties": false,
  "properties": {
    "incidentId": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "solutions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
