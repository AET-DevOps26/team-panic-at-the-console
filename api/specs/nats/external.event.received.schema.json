{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://github.com/aet-devops26/team-panic-at-the-console/api/specs/nats/external.event.received.schema.json",
  "type": "object",
  "required": ["sourceId", "eventType", "timestamp", "rawPayload"],
  "additionalProperties": false,
  "properties": {
    "sourceId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "description": "Normalised event type string, e.g. ci_failure, alert_fired" },
    "timestamp": { "type": "string", "format": "date-time" },
    "rawPayload": { "type": "object", "description": "The original webhook payload, preserved verbatim for rule evaluation" }
  }
}
