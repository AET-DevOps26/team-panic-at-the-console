# Docker image tag (override to run a specific release)
IMAGE_TAG=latest

# Postgres (shared dev instance. One DB per service)
POSTGRES_USER=devops
POSTGRES_PASSWORD=devops

# Shared service defaults
NATS_URL=nats://nats:4222

# GenAI
# Provider: "ollama" (local default) or "logos" (TUM chair model, needs eduVPN).
LLM_PROVIDER=ollama
LLM_FALLBACK_ENABLED=false
# Logos (TUM): only set when LLM_PROVIDER=logos. Key is a secret, never commit it.
LOGOS_API_KEY=
